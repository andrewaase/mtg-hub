VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# eBay Developer Credentials (add these in Netlify → Site Settings → Environment Variables)
# Get these from: https://developer.ebay.com → My Account → Application Keys
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
# RuName is generated by eBay when you add a redirect URI in your app settings.
# Set the redirect URI to: https://your-site.netlify.app/.netlify/functions/ebay-callback
EBAY_RUNAME=your-ebay-runame
