VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe — publishable key is safe to expose in the frontend build
# Add STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET to Netlify env vars (never commit them)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Claude Vision — used by netlify/functions/scan-card.js for card scanning
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# eBay Developer Credentials (add these in Netlify → Site Settings → Environment Variables)
# Get these from: https://developer.ebay.com → My Account → Application Keys
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
# RuName is generated by eBay when you add a redirect URI in your app settings.
# Set the redirect URI to: https://your-site.netlify.app/.netlify/functions/ebay-callback
EBAY_RUNAME=your-ebay-runame

# Resend — transactional email (order confirmations)
# Sign up free at https://resend.com, verify vaultedsingles.com as a sending domain,
# then add RESEND_API_KEY to Netlify → Site Settings → Environment Variables.
# Leave blank to skip confirmation emails (Stripe still sends its own receipt).
RESEND_API_KEY=re_...
